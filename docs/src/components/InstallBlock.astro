---
const cmds = {
  mac: 'curl -sSL https://raw.githubusercontent.com/claudianus/maru-deep-pro-search/main/scripts/install.sh | bash',
  win: 'irm https://raw.githubusercontent.com/claudianus/maru-deep-pro-search/main/scripts/install.ps1 | iex',
};
---

<div class="mx-auto max-w-2xl rounded-xl border border-indigo-500/20 bg-gray-900/80 p-4 backdrop-blur">
  <div class="mb-3 flex gap-2">
    <button data-os="mac" class="install-tab rounded-md px-3 py-1 text-xs font-medium transition bg-indigo-500/20 text-indigo-400">
      macOS / Linux
    </button>
    <button data-os="win" class="install-tab rounded-md px-3 py-1 text-xs font-medium transition text-gray-500 hover:text-gray-300">
      Windows
    </button>
  </div>
  <div class="flex items-center gap-2 rounded-lg bg-gray-950 p-3 font-mono text-sm">
    <span class="text-gray-600">$</span>
    <span id="install-cmd" class="text-emerald-400">{cmds.mac}</span>
    <button id="copy-btn" class="ml-auto rounded p-1 text-gray-500 hover:text-white transition" title="Copy">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <rect x="9" y="9" width="13" height="13" rx="2"/>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
      </svg>
    </button>
  </div>
  <p class="mt-2 text-xs text-gray-500">
    One-liner: installs package + auto-detects your AI agent + injects MCP config + enforces research-first rules.
  </p>
  <p class="mt-1 text-xs text-gray-600">
    No curl? <code class="text-gray-500">pip install maru-deep-pro-search[semantic] && maru-deep-pro-search setup</code>
  </p>
</div>

<script>
  const cmds = {
    mac: 'curl -sSL https://raw.githubusercontent.com/claudianus/maru-deep-pro-search/main/scripts/install.sh | bash',
    win: 'irm https://raw.githubusercontent.com/claudianus/maru-deep-pro-search/main/scripts/install.ps1 | iex',
  };
  const cmdEl = document.getElementById('install-cmd');
  const tabs = document.querySelectorAll('.install-tab');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const os = tab.dataset.os;
      cmdEl.textContent = cmds[os];
      tabs.forEach(t => {
        const isActive = t.dataset.os === os;
        t.className = isActive
          ? 'install-tab rounded-md px-3 py-1 text-xs font-medium transition bg-indigo-500/20 text-indigo-400'
          : 'install-tab rounded-md px-3 py-1 text-xs font-medium transition text-gray-500 hover:text-gray-300';
      });
    });
  });
  document.getElementById('copy-btn')?.addEventListener('click', () => {
    navigator.clipboard.writeText(cmdEl.textContent);
    const btn = document.getElementById('copy-btn');
    btn.innerHTML = '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>';
    setTimeout(() => {
      btn.innerHTML = '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
    }, 1500);
  });
</script>
