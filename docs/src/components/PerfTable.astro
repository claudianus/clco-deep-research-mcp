---
interface Row {
  metric: string;
  target: string;
  impl: string;
}

const rows: Row[] = [
  { metric: 'Cache hit (KnowledgeStore)', target: '<100ms', impl: 'SQLite FTS5 + indexed domain_stats' },
  { metric: 'Full deep_research', target: '<10s', impl: '7 engines, 5 concurrent, early abort at 3 HIGH results' },
  { metric: 'Session startup', target: '~0ms (amortized)', impl: 'Single session reused per engine instance' },
  { metric: 'Semantic model load', target: '~2s (first call)', impl: 'Lazy init, CPU-only' },
  { metric: 'Memory footprint', target: '~150MB base', impl: '+120MB with semantic model. No GPU required.' },
];
---

<div class="overflow-hidden rounded-xl border border-gray-800">
  <table class="w-full text-sm">
    <thead class="bg-gray-800 text-gray-300">
      <tr>
        <th class="px-4 py-3 text-left font-semibold">Metric</th>
        <th class="px-4 py-3 text-left font-semibold">Target</th>
        <th class="px-4 py-3 text-left font-semibold">Implementation</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800">
      {rows.map((r, i) => (
        <tr class={i % 2 === 1 ? 'bg-gray-900/30' : ''}>
          <td class="px-4 py-3 text-gray-300">{r.metric}</td>
          <td class="px-4 py-3 text-emerald-400">{r.target}</td>
          <td class="px-4 py-3 text-gray-400">{r.impl}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
